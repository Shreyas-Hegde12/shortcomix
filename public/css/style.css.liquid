/* BASIC TAGS */
 *{margin:0px 0px 0px 0px; padding:0px 0px 0px 0px; scroll-behavior:smooth!important; -webkit-scroll-behavior:smooth!important; -moz-scroll-behavior:smooth!important;}

body{margin: 0px 0px!important; padding: 0px 0px!important; background-color: var(--primary-bg);}
img{border:none;max-width:100%; height:auto;}
a{text-decoration: none;padding: 0px 0px; margin: 0px 0px;}
ul{padding: 0px 0px; margin: 0px 0px; list-style-position:inside; list-style-type:none;text-decoration: none;}
li{text-decoration: none;}
b{text-decoration: none;}
h1{font-family:acme; font-size: 40px; line-height:0.5;}
h2{font-family:open sans; font-size: 30px; font-weight:thin; line-height:1;}
h3{font-family:gloria hallelujah; font-size: 25px;}
iframe{border: 0px!important;}

::-moz-selection { background-color: transparent;} 
::-webkit-selection { background-color: transparent; }
::selection { background-color: transparent; }
::-webkit-scrollbar{display:none!important;}
p::selection, li::selection, i::selection{ color:white!important; background-color:#e6174b!important;}

input, input:focus {
  outline: none;
  box-shadow: none;
  border: none;
}

.tap-unhighlight, div, .boxes a{
    -webkit-tap-highlight-color: transparent!important;
}

:root
{
--img-newspaper: url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhYj0xkZL1gdOZ28mAVEAdBlkH6TtDzvuqcqH4T9KS9d7D9UH4ZK-2_bf3ytY7GuL8KQWiq-ld6F8DLQlkIqs66Q0ZWH8yQnZsH8b-k9bPBF7OlBoynDBoOESnpir58YBF38dtaQNCuFD2azGVZawLWjysrF4BirWmHukzeK4tIdy6fsoOMDsmRzbQU_Kmz/s0-rw/bgimg--.jpeg');

--img-plain-road: url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgWFR5RbRjtPs19MisoIWhLXxr69gbzJ0pM8OQh7vxQg5xA-0JZdhZXu2Pxj84OxEMxSFJsmAfYcWZ-nxc2jZCIWQslFscEXs5nBiPKK9DX3VxN8Pcp69mneZ75PnGSMGsuJmufyub1IEYj_0NJO5mpr8Wjf9nPMOyAteS9atQziq-yFHi-N-Y7egxcYOvM/s0-rw/e049dbe2-7ac2-431d-9fc5-905c776edc21-14.png');

--like-btn-animation:'';
--like-card-zindex: -5;
--like-card-scale:1;
--like-card-left: calc(49.5%);
--like-msg-appear: 0;
--like-msg-scale:1.1;

--i-am-menu-animation: ;
}

@media(min-width: 650px){
:root{
--like-card-scale: 1.55; 
--like-card-left: calc(52%);
--like-msg-scale: 1.5; 
}}

/*IDs*/
#outer-wrapper{background-color: var(--primary-bg); color: var(--primary-text); max-width:none; width: 100%; overflow:hidden; position:relative; box-sizing:border-box; padding: 0px 0px 0px 0px!important; margin: 0px 0px 0px 0px!important;}
#main-wrapper{background-color: var(--primary-bg); color: var(--primary-text); overflow:visible; box-sizing:border-box; word-wrap:break-word; padding: 0px!important; margin: 0px!important; position:relative;}
#sidebar-wrapper{display: none!important;}
#footer-wrapper{display:none; width: 100%; color: var(--primary-text); font-size: 20px; padding-top: 25px; font-family: open sans; text-align: center; height: 70px; overflow: hidden; background-color: var(--primary-bg); place-items: center;}

#blog-pager-newer-link {float:left;}
#blog-pager-older-link {float:right;}
#disqus_thread iframe{background-color: var(--primary-bg);}
#signaling-copy{width: 100%; height: 100%; padding:5px 7px 5px 7px; background: #eee; font-family:acme!important; color:black; transform:translate(20%,10%);}

/**/

/*CLASSES*/
.blog-feeds{display:none!important;}

.container{position:relative; box-sizing:border-box;}
.nav-prev, .nav-next , .nav-random {position:relative; top: 10px;}

.comicimg{width: 90vw; max-width: 600px; height:auto; margin-top: 10px; filter: saturate(0.8);}
.archive-settings{aspect-ratio: 16/17!important; width: calc(45%); max-width: 230px; border-radius: 25px; height: auto; margin: 5px 5px 5px 5px!important; filter: saturate(0.8); -webkit-filter: saturate(0.8); -moz-filter: saturate(0.8);}
.archive-settings:hover{opacity:0.75;}

.animate-carousel{animation: emoji_pop 2s  infinite;}
.gray-bg{background-color: var(--gray-bg);}
.gray-bg-element{background-color: var(--gray-bg-element);}
.back{background-color: var(--gray-bg-element);} 
.bar-sticks{background-color: var(--gray-bg-element); opacity: 0.9; }
.plain-link{color: var(--dull-text-clr);}
.reveal-menu-icon{animation: reveal_menu_icon 2s 1; animation-fill-mode: forwards; animation-delay: 2s;}

.menu-social-icons a{
fill:white!important;
aspect-ratio: 1/1;
}
.mobile-menu {
display: flex;
width: 100vw;
height: 100%;
clip-path: circle(0% at 50% 92%);
will-change: clip-path;
position: fixed;
bottom: 0px;
left: 0px;
z-index: 6000;
justify-content:center;
place-items:center;
}
.mobile-menu ul{
position:relative;
width: 90%;
display: flex;
flex-direction: column;
justify-content:center;
place-items:center;
gap: 5vw;
transform: translateY(-5%);
}
.mobile-menu ul li {
width:100%;
height: auto;
max-width: 650px;
list-style: none;
aspect-ratio: 30/7.8;
overflow: hidden;
font-family: Gloria Hallelujah;
font-size: 10.1vw;
}
.mobile-menu li a{width: 100%; color: white!important;}
.mobile-menu li a:hover {color: yellow!important;}

.tag-tick-tick{
animation: hashtag_tick_tick steps(2) 1s infinite;
transition: 1s linear infinite;
}
.home-tag:hover{
color:yellow!important;
}

.spill ul {
position:relative; 
}
.spill ul a{
font-size: 3.8vw!important;
color: white!important;
font-family: gloria hallelujah;
}
.spill li{padding-bottom: 8%;}
.spill li:nth-last-child(1){padding-bottom: 0px!important;}
.spill a:hover{color:yellow!important;}

.desktop-menu{display:none; position: fixed; top: 0px; width: 100vw; height: 7vw; max-height: 80px; border-radius: 0px; background-color: #121212; z-index: 1000; justify-content:center; place-items:center; overflow:hidden; }
.desktop-menu a{color: white;}
.desktop-menu ul{display:flex; flex-direction: row; width: 100%; height: 100%; gap: 5%; justify-content:center; place-items:center; }
.desktop-menu li{font-size:2.1vw; opacity:1; font-weight: 600; font-family: gloria hallelujah;position:relative;}
.desktop-menu a:hover{color:white;}

/**/


/*Media Screen Size*/
@media(max-width:560px) {.emoji-settings{width: 19vw; height:auto; max-width: 240px; position: relative; z-index: 10; bottom: -10px;}}
@media(max-width:820px){.desktop-menu{display:none!important;}}

@media(max-width:650px){

#fixed-background {
display:none;
background-repeat: repeat-y;
background-image: var(--img-newspaper);
background-position: 0px -210px;
background-size: cover;
margin-bottom: -10px;
height:116vh;
position:relative;
box-shadow: 0 0 70px 70px #fff;
width: 100%;
scroll-behavior:smooth!important;
margin-top:0px!important;
clip-path: polygon(0% 0%, 100% 0, 100% 89%, 50% 100%, 0 89%);
-webkit-clip-path: polygon(0% 0%, 100% 0, 100% 89%, 50% 97%, 0 89%); 
-moz-clip-path: polygon(0% 0%, 100% 0, 100% 89%, 50% 97%, 0 89%);
filter: saturate(0) contrast(0.99) opacity(0.85) brightness(1.05);
-webkit-filter: saturate(0) contrast(0.99) opacity(0.85) brightness(1.05);
-moz-filter: saturate(0) contrast(0.99) opacity(0.85) brightness(1.05);
}

.common-gap {margin-top:5%;}
.carousel{position:absolute; top:45vh; left: 50vw; transform:translate(-50%,-50%); transition: top 2s ease; z-index: 500;}
.emoji-carousel{width: 60vw;}
.for-laptop{display:none!important;}

.nav-next:hover {animation: nav-next 1.2s 1; transition: linear 1.2s 1;}
.nav-prev:hover {animation: nav-prev 1.2s 1; transition: linear 1.2s 1;}
}

@media(min-width:650px){

#fixed-background {
display:none;
background-repeat: repeat;
background-image: var(--img-newspaper);
background-position: 10% -140%;
background-size: 70%;
margin-bottom: 20px;
height:130vh;
position:relative;
width: 100%;
scroll-behavior:smooth!important;
margin-top:0%!important;
filter: saturate(0) contrast(1) opacity(0.85) brightness(1.05);
-webkit-filter: saturate(0) contrast(1) opacity(0.85) brightness(1.05);
-moz-filter: saturate(0) contrast(1) opacity(0.85) brightness(1.05);
clip-path: polygon(0% 0%, 100% 0, 100% 88%, 50% 100%, 0 88%);
-webkit-clip-path: polygon(0% 0%, 100% 0, 100% 88%, 50% 100%, 0 88%);
-moz-clip-path: polygon(0% 0%, 100% 0, 100% 88%, 50% 100%, 0 88%);
}
#open-mobile-menu{display:none!important;}

.common-gap {margin-top: 6%;}
.carousel{position:absolute; top:50vh!important; left: 50vw!important; transform:translate(-50%,-50%); z-index: 500;}
.emoji-carousel{width:50vw;}
.for-mobile{display: none!important;} 
}

@media(min-width:500px){
	.social-icons{margin:-1% 0 2% 0!important; aspect-ratio:23/3!important;} 
	.emoji-settings{width: 14vw; height:auto; max-width: 100px; position: relative;z-index: 10; bottom: -7px;}
}
@media(min-width:820px){
#comic-title{font-size: 240%!important;} 
.d-bar-graph {display:flex!important;} 
.d-tv-and-controls{margin-left:2.4%;}
.open-comments-section p{font-size: 165%!important;} 
.comicimg{margin-top:45px!important; } 
.desktop-menu{display:block;}
}
@media(min-width:1000px){
#fixed-background{background-size: 43%!important; clip-path: polygon(0% 0%, 100% 0, 100% 85%, 50% 100%, 0 85%);}
.emoji-carousel{width: 26vw!important;}
#d-kiddo-peek { width: 23vw!important; }
.d-comic-square { width: 20vw!important; }
.d-tv-frame{width:41%;}
}


/* COLOR PREFERENCE */
@media(prefers-color-scheme: light)
{
:root {--primary-bg: #fff; --primary-text: #000; --gray-bg: #eee; --gray-bg-element: #ddd; --dull-text-clr: #222; --comic-square-shadow: #ccc;}

#open-mobile-menu{background: white; box-shadow: 0px 0px 35px 30px #f5f5f5; border: 6px solid #fff;}
#hcb_form_content{background-color: #ddd;}

.comicimg.back{background: #bbb;}
.social-icons{fill: #121212!important}
.comment,.hcb-wrapper{background-color:#eee;}
}

@media(prefers-color-scheme: dark)
{
:root {--primary-bg: #252525; --primary-text: #fff; --gray-bg: #171717; --gray-bg-element: #333; --dull-text-clr: #eee; --comic-square-shadow: #000;}

#open-mobile-menu {background: black; box-shadow: 0px 0px 65px 55px black; border: 6px solid #555; } 
#hcb_form_content {background-color: #333;}

.frog-like-btn::before {box-shadow: inset 0px 0px 2px 4px rgba(0,0,0,1)!important;}
.social-icons svg{fill: white!important}
.hcb-wrapper, .comment{background-color:#171717!important;}
 @media(max-width:650px){
   #fixed-background{-webkit-filter: saturate(0) contrast(0.9) brightness(0.5); -moz-filter: saturate(0) contrast(0.9) brightness(0.5); filter: saturate(0) contrast(0.9) brightness(0.5);
}}
 @media(min-width:650px){
   #fixed-background{-webkit-filter: saturate(0) contrast(0.9) brightness(0.5); -moz-filter: saturate(0) contrast(0.9) brightness(0.5); filter: saturate(0) contrast(0.9) brightness(0.5);}
.desktop-menu{ overflow: visible!important; background: rgba(0,0,0,0.9)!important; backdrop-filter: blur(20px);}
}
}


/* Keyframes */
@keyframes nav-next{
10%{transform: translateX(30px);} 
40%{transform: translateX(0px);}
}
@keyframes nav-prev{
10%{transform: rotate(180deg) translateX(30px);} 
40%{transform: rotate(180deg) translateX(0px);}
}

@keyframes hashtag_tick_tick {
from{transform: rotateZ(9deg);}
to{transform: rotateZ(-20deg);}
}
@keyframes shake_on_hover {
0% { transform: translate(0px, 0px) rotate(0deg);}
10% { transform: translate(-1px, -6px) rotate(-1deg);}
15% { transform: translate(-3px, 0px) rotate(1deg);}
30% { transform: translate(4px, 5px) rotate(0deg);}
40% { transform: translate(1px, -1px) rotate(1deg);}
45% { transform: translate(-1px, 4px) rotate(-3deg);}
55% { transform: translate(-4px, 1px) rotate(0deg);}
65% { transform: translate(2px, 1px) rotate(-1deg);}
70% { transform: translate(-2px, -1px) rotate(1deg);}
80% { transform: translate(-1px, -1px) rotate(1deg);}
95% { transform: translate(0px, 0px) rotate(0deg);}
}

@keyframes emoji_pop {
 15%{transform: scale(0.8) rotateZ(10deg); opacity: 0.83;}
 50%{transform: scale(1) rotateZ(0deg); opacity: 1;} 
 95%{transform: scale(1) rotateZ(0deg); opacity: 1;}
 100%{transform: scale(1) rotateZ(0deg); opacity: 1;}
}

@keyframes like_plus_one 
{
15%{transform: rotate(10deg) translate(-47%,-10px) scale(var(--like-card-scale)); opacity:1;}
90%{transform: rotate(5deg) translate(-47%,-70px) scale(var(--like-card-scale)); opacity:1;}
100%{transform: rotate(-2deg) translate(-48%,-102px) scale(var(--like-card-scale)); opacity:0;}
}

@keyframes appear_disappear 
{
0%{transform: translate(-50%,0) rotate(10deg); opacity:0; width: 125%;}
25%{transform: rotate(10deg) translate(-50%,-0%); opacity:1; width: 125%;}
50%{transform: rotate(15deg) translate(-50%,-10%); opacity:1; width: 125%;}
75%{transform: rotate(10deg) translate(-50%, -0%); opacity:1; width: 125%;}
100%{transform: rotate(10deg) translate(-50%,0%); opacity:0; width: 125%;}
}
@keyframes reveal_menu_icon
{
0%{clip-path: circle(100%); }
100%{clip-path: circle(0%); }
}

  
/* Pseudo Elements */
.frog-like-btn::before
{
content: ' +1 🩷Like ';
font-size: 30px;
line-height: 1.2;
font-family: indie flower;
padding: 5px 9px 5px 9px;
color: white;
width:78px;
height: 90px; 
aspect-ratio: 16/15.8!important;
overflow:hidden;
background:red;
display:flex;
justify-content:center;
place-items: center;
position: absolute;
left: var(--like-card-left);
z-index: var(--like-card-zIndex);
transform:rotate(12deg) translate(-50%,60px) scale(var(--like-card-scale));
opacity: 0;
border-radius: 4px;
box-shadow: inset 0px 0px 2px 4px rgba(255,255,255,1);
transition: linear 2s 1;
animation: var(--like-btn-animation);
animation-fill-mode: forwards;
}
.frog-like-btn::after
{
content: 'U stole my heart!';
font-size: 19px;
font-family: open sans;
position:absolute;
top:70%;
left: calc(50%);
width: 100%;
max-width: 120px;
height: auto;
overflow:hidden;
aspect-ratio: 2/0.85;
color:white;
padding: 6px 0px 6px 0px;
background: rgba(0,0,0,0.8);
opacity: var(--like-msg-appear);
z-index: var(--like-card-zIndex);
transform: translate(-47%,-50%) scale(var(--like-msg-scale));
transition: opacity linear 1s;
}

#open-mobile-menu::before
{
content: '';
background: url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgsB4KRZ4QnpWK60ktz4c23UVlmOJzuUCDaclQ7LLQDuLTTQDlijWbDP29ZfqVb0KuoH78gHa3A9KGMqHZjg9ZPih-bDHemcX3rWvaPbhJWpcJBCiBWc-Nt62PP3X7GrE0U_-qiyZyhDmKyobz51fOvkieRTyY3tUjBOkOTOrZ3A9i2y1SoKVon97QFmOzM/s0-rw/ScreenShot2021-05-31at2.20.46PM-removebg-preview.png') center no-repeat;
background-size: cover;
position: absolute; top: -90%; left: 90%;
transform: translate(-50%,0) rotate(10deg);
animation: var(--i-am-menu-animation);
animation-delay: 0;
opacity: 0;
z-index: 15;
display: block;
width: 0px; height: auto; aspect-ratio: 1/1;
}